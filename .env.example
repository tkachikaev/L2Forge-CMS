APP_NAME="KaevCMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Europe/Moscow
APP_FORCE_HTTPS=false

# Comma-separated proxy IP addresses or CIDR ranges. Leave empty unless the site is behind Cloudflare or another reverse proxy.
TRUSTED_PROXIES=

# Public-site defaults used until values are saved in the CMS database.
SITE_NAME="KaevCMS"
SITE_DESCRIPTION="Бесплатная open-source CMS для серверов Lineage II."
SITE_ADMIN_EMAIL=
SITE_FOOTER_TEXT="© 2026 KaevCMS"
SITE_SHOW_PUBLIC_ONLINE=true

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

# Password hashing for CMS users and administrators.
HASH_DRIVER=auto
HASH_VERIFY=true
BCRYPT_ROUNDS=12
ARGON_MEMORY=65536
ARGON_THREADS=2
ARGON_TIME=4

# KaevCMS database. SQLite is enough for local development.
DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite
DB_BUSY_TIMEOUT=5000
# Optional SQLite-only tuning. Leave unset unless you explicitly need it.
# DB_JOURNAL_MODE=WAL
# DB_SYNCHRONOUS=NORMAL

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_COOKIE=kaevcms_session
SESSION_SECURE_COOKIE=false
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Administrator login protection.
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_DECAY_SECONDS=60
ADMIN_LOGIN_IP_MAX_ATTEMPTS_PER_MINUTE=10
ADMIN_LOGIN_IP_MAX_ATTEMPTS_PER_HOUR=100
ADMIN_LOGIN_LOG_RETENTION_DAYS=30
ADMIN_2FA_MAX_ATTEMPTS_PER_MINUTE=5
ADMIN_2FA_MAX_ATTEMPTS_PER_HOUR=20

# Human-readable audit log retention.
AUDIT_LOG_RETENTION_DAYS=90

# Active frontend theme.
CMS_THEME=default
CMS_ACCOUNT_THEME=luxury

# Game adapter: mock or mobius.
GAME_ADAPTER=mock
GAME_SERVER_NAME="L2Server x1"
GAME_CHRONICLE="High Five"
GAME_RATES=x1
GAME_MODE=PvP
GAME_MAX_ONLINE=5000
GAME_SERVER_HOST=127.0.0.1
GAME_SERVER_PORT=7777
GAME_LOGIN_HOST=127.0.0.1
GAME_LOGIN_PORT=2106

# LoginServer/GameServer monitoring. Public and admin pages refresh stale data automatically.
# The refresh interval is a fallback until it is saved in Admin -> System. Allowed UI values: 30, 60, 120, 300.
SERVER_MONITOR_REFRESH_INTERVAL_SECONDS=60
# Internal lock protection. CMS enforces a minimum of 150 seconds.
SERVER_MONITOR_LOCK_SECONDS=300
SERVER_MONITOR_PORT_TIMEOUT_SECONDS=1
SERVER_MONITOR_FAILURE_THRESHOLD=3
SERVER_MONITOR_STATUS_STALE_SECONDS=180
SERVER_MONITOR_ONLINE_STALE_SECONDS=300

# External LoginServer and GameServer database safety limits.
EXTERNAL_DB_CONNECT_TIMEOUT_SECONDS=3
EXTERNAL_DB_QUERY_TIMEOUT_MS=3000
EXTERNAL_DB_CHARACTER_LIMIT=50

# Separate least-privilege connection to the Mobius database.
GAME_DB_HOST=127.0.0.1
GAME_DB_PORT=3306
GAME_DB_DATABASE=l2jmobius
GAME_DB_USERNAME=kaevcms
GAME_DB_PASSWORD=change_me
GAME_DB_CHARSET=utf8mb4

# Public website users. Database settings from the admin panel override these defaults.
REGISTRATION_ENABLED=false
REGISTRATION_EMAIL_VERIFICATION=true

# Safe fallback until SMTP is configured through the admin panel.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
