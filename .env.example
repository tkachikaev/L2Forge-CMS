APP_NAME="L2Forge CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Europe/Moscow
APP_FORCE_HTTPS=false

# Public-site defaults used until values are saved in the CMS database.
SITE_NAME="L2Forge CMS"
SITE_DESCRIPTION="Бесплатная open-source CMS для серверов Lineage II."
SITE_ADMIN_EMAIL=
SITE_FOOTER_TEXT="© 2026 L2Forge-CMS"

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

# Password hashing for CMS users and administrators.
HASH_DRIVER=argon2id
ARGON_MEMORY=65536
ARGON_THREADS=2
ARGON_TIME=4

# L2Forge CMS database. SQLite is enough for local development.
DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
CACHE_STORE=file
QUEUE_CONNECTION=database

# Administrator login protection.
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_DECAY_SECONDS=60
ADMIN_LOGIN_IP_MAX_ATTEMPTS_PER_MINUTE=10
ADMIN_LOGIN_IP_MAX_ATTEMPTS_PER_HOUR=100
ADMIN_LOGIN_LOG_RETENTION_DAYS=30

# Human-readable audit log retention.
AUDIT_LOG_RETENTION_DAYS=90

# Active frontend theme.
CMS_THEME=default

# Game adapter: mock or mobius.
GAME_ADAPTER=mock
GAME_SERVER_NAME="L2Server x1"
GAME_CHRONICLE="High Five"
GAME_RATES=x1
GAME_MODE=PvP
GAME_MAX_ONLINE=5000
GAME_SERVER_HOST=127.0.0.1
GAME_SERVER_PORT=7777
GAME_LOGIN_HOST=127.0.0.1
GAME_LOGIN_PORT=2106

# Separate least-privilege connection to the Mobius database.
GAME_DB_HOST=127.0.0.1
GAME_DB_PORT=3306
GAME_DB_DATABASE=l2jmobius
GAME_DB_USERNAME=l2forge
GAME_DB_PASSWORD=change_me
GAME_DB_CHARSET=utf8mb4

# Public website users. Database settings from the admin panel override these defaults.
REGISTRATION_ENABLED=false
REGISTRATION_EMAIL_VERIFICATION=true

# Safe fallback until SMTP is configured through the admin panel.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
